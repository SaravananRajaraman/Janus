<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler — auto-start Janus at login.

  Import via:
    schtasks /create /xml scripts\task.xml /tn "Janus Organiser"

  Or: Task Scheduler → Action → Import Task → select this file.

  IMPORTANT: Edit the <Command> path to match your Python environment.
  Run  `where python`  in the Janus directory to get the correct path.
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Janus AI file organiser — watches folders and presents approval queue in browser dashboard.</Description>
    <Author>Janus</Author>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- Replace C:\Python313\python.exe with your actual Python path -->
      <Command>C:\Python313\python.exe</Command>
      <Arguments>-m src.main start</Arguments>
      <!-- Replace with the full path to your Janus project directory -->
      <WorkingDirectory>D:\Projects\Janus</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
